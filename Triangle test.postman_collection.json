    {
      "name": "Valid traingle",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Triangle is valid\", function () {\r",
              "    let json = pm.response.json();\r",
              "    pm.expect(json.valid).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.test(\"Correct perimeter\", function () {\r",
              "    let json = pm.response.json();\r",
              "    pm.expect(json.perimeter).to.eql(12);\r",
              "});\r",
              "\r",
              "pm.test(\"Correct area\", function () {\r",
              "    let json = pm.response.json();\r",
              "    pm.expect(json.area).to.eql(6);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
